DATABASE_URL="file:./dev.db"

# Slack App Configuration
# Get these from https://api.slack.com/apps
SLACK_BOT_TOKEN="xoxb-your-bot-token"
SLACK_SIGNING_SECRET="your-signing-secret"

# Dashboard Basic Auth (required — dashboard will return 500 without these)
DASHBOARD_USERNAME="admin"
DASHBOARD_PASSWORD="change-me-before-deploying"

# Public URL of your deployed app (used by Slack commands to call internal APIs)
NEXT_PUBLIC_APP_URL="https://your-railway-app.up.railway.app"
